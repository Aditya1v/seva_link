{
  "name": "reliefsync-ai-workspace",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "api": "npm run dev:server",
    "build": "npm run build --workspace client",
    "typecheck": "npm run typecheck --workspace client",
    "test": "npm run test --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
